# dotenvx — encrypted .env is safe to commit, .env.keys is NOT
.env.keys
.env.vault
.env.previous

# Stray Hermes home: running `hermes` from the repo outside dotenvx reads the
# encrypted HERMES_HOME as a literal path and creates a junk home named after
# the ciphertext (with auth state inside). Never commit it. (issue 25e947a)
encrypted:*

# Dependencies
node_modules/

# Runtime artifacts
.link_cache.json
.session_cache.json
# Transient recap context offloaded for Hermes @file: injection (issue 1f154fc);
# cleaned up after each call, but ignore in case a crash orphans one.
.hermes-recap-ctx-*.txt
*.log

# PM2
.pm2/
dump.pm2

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
